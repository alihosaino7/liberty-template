

.item-preview__content {
   display: flex;
   align-items: center;
   justify-content: space-between;
   flex-wrap: wrap;
   row-gap: 2rem;
}

.item-preview__content__image {
   flex-basis: 55%;
   height: 450px;
}

@media (max-width: 991px) {
   .item-preview__content__image {
      flex-basis: 100%;
   }
}

.item-preview__content__image img {
   border-radius: 1.2rem;
   width: 100%;
   height: 100%;
}

.item-preview__content__info {
   flex-basis: 40%;
   color: #fff;
}

@media (max-width: 991px) {
   .item-preview__content__info {
      flex-basis: 100%;
   }
}

@media (max-width: 480px) {
   .item-preview__content__info {
      text-align: center;
   }
}

.item-preview__content__info .author {
   border-bottom: 0;
   margin-bottom: 0;
}

@media (max-width: 480px) {
   .item-preview__content__info .author {
      width: fit-content;
      margin: 0 auto;
   }
}

.item-preview__content__info > p {
   line-height: 1.8;
   margin-bottom: 1.5rem;
   font-size: .95rem;
}

.item-preview__content__info__row {
   display: flex;
   justify-content: space-between;
   align-items: center;
}

@media (max-width: 480px) {
   .item-preview__content__info__row {
      flex-direction: column;
   }
}

.item-preview__content__info__row:last-child {
   margin-top: 2.5rem;
   justify-content: flex-start;
   gap: 1.5rem;
}

.item-preview__content__info__row :is(h4, span) {
   color: #ccc;
}

.item-preview__content__info__col > * {
   line-height: 2rem;
}

@media (max-width: 480px) {
   .item-preview__content__info__col {
      text-align: center;
   }
}

.item-preview__content__info__col > h3 {
   color: var(--primary-color);
}


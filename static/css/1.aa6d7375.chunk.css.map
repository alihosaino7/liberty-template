
.categories {
   margin-bottom: 150px;
}

.categories__items {
   display: flex;
   justify-content: center;
   align-items: center;
   gap: 1.5rem;
   flex-wrap: wrap;
}

@media (max-width: 991px) {
   .categories__items {
      gap: 2rem 1.5rem;
   }
}

.category__item {
   position: relative;
   border: 1px solid var(--gray-color);
   background-color: var(--dark-gray-color);
   border-radius: 1rem;
   text-align: center;
   padding: 2rem 0;
   flex: 0 0 15%;
}

@media (max-width: 991px) {
   .category__item {
      flex: 0 0 30%;
   }
}

@media (max-width: 767px) {
   .category__item {
      flex: 0 0 47%;
      padding: 2.5rem;
   }
}

@media (max-width: 767px) {
   .category__item {
      flex: 0 0 100%;
   }
}

.category__img {
   background-color: #fff;
   border-radius: 50%;
   margin: 0 auto 1rem;
   width: 70px;
   height: 70px;
   display: flex;
   align-items: center;
   justify-content: center;
}

.category__img img {
  object-fit: cover;
}

.category__item h3 {
   color: #fff;
   white-space: nowrap;
}

.category__item__btn {
   opacity: 0;
   background-color: #fff;
   transition: .3s;
   color: var(--primary-color);
   position: absolute;
   left: 50%;
   bottom: -30px;
   transform: translateX(-50%);
   border-radius: 50%;
   width: 50px;
   height: 50px;
   display: grid;
   place-items: center;
   font-size: 1.5rem;
   cursor: pointer;
}

.category__item__btn:hover {
   background-color: var(--primary-color);
   color: #fff;
}

.category__item:hover .category__item__btn {
   opacity: 1;
}
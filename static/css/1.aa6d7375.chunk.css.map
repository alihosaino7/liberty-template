
.collections-slider {
   width: 100%;
   /* padding: 0 1rem; */
}

.collections-slider .slick-slide > div {
   margin: 0 1rem;
 }

 .collections-slider .slick-list {
   margin: 0 -1rem;
   height: 600px;
 }

.collections__item {
   width: 100%;
   background-color: var(--dark-gray-color);
   border-radius: 1.5rem;
   position: relative;
}

.collections__item--image {
   overflow: hidden;
   border-top-left-radius: 1.5rem;
   border-top-right-radius: 1.5rem;
}

.collections__item--image img {
   width: 100%;
   height: 100%;
   object-fit: cover;
}

.collections__item--content {
   border: 1px solid var(--gray-color);
   border-bottom-left-radius: 1.5rem;
   border-bottom-right-radius: 1.5rem;
   color: #fff;
   padding: 1rem 2rem 3rem;
}

.collections__item--content > h3 {
   padding: 1rem 0;
   border-bottom: 2px solid var(--gray-color);
   margin-bottom: 1.1rem;
}

.collections__item--content__row-1,
.collections__item--content__row-2 {
   margin: .2rem 0;
   display: flex;
   align-items: center;
   justify-content: space-between;
}

.collections__item .secondary-button {
   width: 80%;
   position: absolute;
   z-index: 1000;
   bottom: -20px;
   left: 50%;
   transform: translateX(-50%);
}
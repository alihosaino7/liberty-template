

.author {
   display: flex;
   align-items: center;
   padding: 1.5rem 0;
   border-bottom: 1px solid var(--gray-color);
}

.author img {
   border-radius: 50%;
   max-width: 50px;
   max-height: 50px;
   /* object-fit: cover; */
   margin-right: 1rem;
}

.author p {
   line-height: 1.5;
   color: #fff;
}

.author h4 {
   color: var(--primary-color);
}

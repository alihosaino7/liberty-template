

.heading-section {
   width: fit-content;
   margin: 0 auto 80px;
   position: relative;
   text-align: center;
}

@media (max-width: 767px) {
   .heading-section {
      margin: 0 auto 60px;
   }
}

.heading-section::before {
   content: '';
   position: absolute;
   top: -30px;
   left: 50%;
   transform: translateX(-50%);
   background-color: var(--primary-color);
   width: 18%;
   height: 2px;
}

.heading-section h1 {
   color: #fff;
   text-transform: capitalize;
}

@media (max-width: 767px) {
   .heading-section h1 {
      font-size: 1.6rem;
   }
}

.heading-section span {
   color: var(--primary-color);
}
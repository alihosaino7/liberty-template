

.custom-select {
   width: 150px;
   position: relative;
   border: 1px solid var(--gray-color);
   border-radius: 1.5rem;
   padding: .8rem 1.2rem;
   background-color: transparent;
   color: #fff;
}

.arrow-down {
   position: absolute;
   top: 50%;
   transform: translateY(-50%);
   right: 1rem;
   cursor: pointer;
   color: #ccc;
   font-size: 1.1rem;
   transition: .2s;
}

.arrow-down.rotate-arrow {
   transform: translateY(-50%) rotate(180deg);
}

.options-list {
   transition: .3s;
   width: 100%;
   position: absolute;
   top: calc(100% + 20px);
   left: 0;
   background-color: var(--dark-gray-color);
   overflow-y: hidden;
   height: 0;
   z-index: 1500;
}

.options-list::-webkit-scrollbar {
   width: 10px;
}

.options-list::-webkit-scrollbar-track {
   background-color: var(--dark-gray-color);
}

.options-list::-webkit-scrollbar-thumb {
   background-color: hsla(0, 0%, 80%, 60%);
   transition: .2s;
}

.options-list::-webkit-scrollbar-thumb:hover {
   background-color: hsla(0, 0%, 80%, 80%);
}

.options-list.opened {
   height: fit-content;
}

.options-list.auto {
   overflow-y: scroll;
}

.options-list .option {
   text-align: center;
   cursor: pointer;
   padding: .5rem 0;
   width: 100%;
   height: 20%;
   transition: .3s, opacity .1s;
   opacity: 0;
}

.options-list.opened .option {
   opacity: 1;
}

.options-list .option:hover {
   color: var(--dark-gray-color);
   background-color: #fff;
}
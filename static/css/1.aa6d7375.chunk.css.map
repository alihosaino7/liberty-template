

.item-details {
   padding-top: 120px;
   padding-bottom: 120px;
   background-image: url('../../assets/dark-bg.jpg');
   /* background-repeat: no-repeat; */
   min-height: 150vh;
}

.item-details__content {
   display: flex;
   align-items: center;
   justify-content: space-between;
   flex-wrap: wrap;
   row-gap: 2rem;
}

.item-details__content__image {
   flex-basis: 55%;
   height: 450px;
}

@media (max-width: 991px) {
   .item-details__content__image {
      flex-basis: 100%;
   }
}

.item-details__content__image img {
   border-radius: 1.2rem;
   width: 100%;
   height: 100%;
}

.item-details__content__info {
   flex-basis: 40%;
   color: #fff;
}

@media (max-width: 991px) {
   .item-details__content__info {
      flex-basis: 100%;
   }
}

@media (max-width: 480px) {
   .item-details__content__info {
      text-align: center;
   }
}

.item-details__content__info .author {
   border-bottom: 0;
   margin-bottom: 0;
}

@media (max-width: 480px) {
   .item-details__content__info .author {
      width: fit-content;
      margin: 0 auto;
   }
}

.item-details__content__info > p {
   line-height: 1.8;
   margin-bottom: 1.5rem;
   font-size: .95rem;
}

.item-details__content__info__row {
   display: flex;
   justify-content: space-between;
   align-items: center;
}

@media (max-width: 480px) {
   .item-details__content__info__row {
      flex-direction: column;
   }
}

.item-details__content__info__row:last-child {
   margin-top: 2.5rem;
   justify-content: flex-start;
   gap: 1.5rem;
}

.item-details__content__info__row :is(h4, span) {
   color: #ccc;
}

.item-details__content__info__col > * {
   line-height: 2rem;
}

@media (max-width: 480px) {
   .item-details__content__info__col {
      text-align: center;
   }
}

.item-details__content__info__col > h3 {
   color: var(--primary-color);
}

.current-bid {
   margin-top: 100px;
}

.current-bid__header {
   display: flex;
   align-items: center;
   justify-content: space-between;
   margin-bottom: 60px;
}

@media (max-width: 767px) {
   .current-bid__header {
      flex-direction: column;
      margin-bottom: 30px;
   }
}

.current-bid__header .main-button {
   font-weight: var(--fw-bold);
   font-size: 1.2rem;
   letter-spacing: 0;
   text-transform: capitalize;
}

@media (max-width: 767px) {
   .current-bid__header .main-button {
      margin-bottom: 1.5rem;
   }
}


.current-bid__header .custom-select {
   width: 175px;
}

.current-bid__items {
   display: flex;
   flex-wrap: wrap;
   gap: 1.5rem;
}

.current-bid__item {
   background-color: var(--dark-gray-color);
   border: 1px solid var(--gray-color);
   display: flex;
   color: white;
   flex-basis: calc(33% - 1rem);
   border-radius: 1.5rem;
   overflow: hidden;
}

@media (max-width: 991px) {
   .current-bid__item {
      flex-basis: calc(50% - 1rem);
   }
}

@media (max-width: 767px) {
   .current-bid__item {
      flex-basis: 100%;
   }
}

.current-bid__item__image {
   height: 100%;
   flex-basis: 40%;
}

.current-bid__item__image img {
   height: 100%;
   width: 100%;
}

.current-bid__item__content {
   padding: 2rem;
}

.current-bid__item__content :is(h4, span h3, time) {
   color: var(--primary-color);
}

.current-bid__item__content span {
   display: flex;
   align-items: center;
   gap: .3rem;
}

.current-bid__item__content-top {
   padding-bottom: 1.5rem;
}

.current-bid__item__content-bottom {
   padding-top: 1.5rem;
   border-top: 2px solid var(--gray-color);
}

.current-bid__item__content-bottom > * {
   line-height: 2;
}


.author-page {
   padding-top: 120px;
   padding-bottom: 150px;
   background-image: url('../../assets/dark-bg.jpg');
   min-height: 100vh;
   color: #fff;
}

.author-page-info {
   display: flex;
   align-items: center;
   justify-content: space-between;
   margin-bottom: 100px;
}

@media (max-width: 991px) {
   .author-page-info {
      flex-direction: column;
      row-gap: 1.5rem;
   }
}

.author-page-info__left {
   display: flex;
   align-items: center;
}

@media (max-width: 420px) {
   .author-page-info__left {
      flex-direction: column;
      text-align: center;
   }
}

.author-page-info__left img {
   width: 170px;
   height: 170px;
   border-radius: 50%;
   margin-right: 2rem;
}

@media (max-width: 420px) {
   .author-page-info__left img {
      margin: 0 0 1rem 0;
   }
}

.author-page-info__right {
   width: 40%;
   padding: 1.2rem 2rem;
   background-color: var(--dark-gray-color);
   border: 1px solid var(--gray-color);
}

@media (max-width: 991px) {
   .author-page-info__right {
      width: 100%;
   }
}

.author-page-info__right__row-1 {
   display: flex;
   justify-content: space-between;
   margin-bottom: 2rem;
}

@media (max-width: 420px) {
   .author-page-info__right__row-1 {
      flex-direction: column;
      align-items: center;
      text-align: center;
   }
   .author-page-info__right__row-1 div {
      margin-bottom: 1rem;
   }
}

.author-page-info__right__row-1 .icon {
   font-size: 2rem;
}

.author-page-info__right__row-1 p {
   font-size: 1rem;
}

.author-page-info__right__row-1 span {
   font-weight: bold;
   font-size: 1.1rem;
}

.author-page-info__right__row-2 {
   display: flex;
   justify-content: space-between;
   align-items: center;
}

@media (max-width: 420px) {
   .author-page-info__right__row-2 {
      flex-direction: column;
      text-align: center;
   }
}

.author-page-info__right__row-2 h3 {
   color: #ccc;
}

@media (max-width: 420px) {
   .author-page-info__right__row-2 h3 {
      margin-bottom: 1rem;
   }
}

.author-page__items {
   display: grid;
   grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
   gap: 2.5rem 1.5rem;
}

.author-page__items .discover-items__item {
   width: 100%;
}

.author-page__items .discover-items__item .link {
   width: 70%;
}

.author-page__items .discover-items__item .link .secondary-button {
   width: 100%;
}